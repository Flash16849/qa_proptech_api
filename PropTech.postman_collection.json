          "name": "GET - Get All Properties",
          "item": [
            {
              "name": "Get All Properties - 200 OK",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "var jsonData = pm.response.json();",
                      "",
                      "pm.test(\"Response should have correct structure\", function () {",
                      "    pm.expect(jsonData).to.have.property('total');",
                      "    pm.expect(jsonData).to.have.property('data');",
                      "    pm.expect(jsonData.data).to.be.an('array');",
                      "});",
                      "",
                      "pm.test(\"Response has correct data structure\", function () {",
                      "    jsonData.data.forEach(item => {",
                      "        pm.expect(item).to.have.property('_id');",
                      "        pm.expect(item).to.have.property('name');",
                      "        pm.expect(item).to.have.property('location');",
                      "        pm.expect(item.price).to.be.a('number');",
                      "    })",
                      "});"
                    ],
                    "type": "text/javascript",
