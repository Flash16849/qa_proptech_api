        {
          "name": "POST - Create Property",
          "item": [
            {
              "name": "Create Property - 201 Created",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Successful POST request\", function () {",
                      "    pm.expect(pm.response.code).to.be.oneOf([201, 202]);",
                      "});",
                      "",
                      "var propID = pm.response.json()._id;",
                      "var tag = pm.response.json().tags[0]",
                      "",
                      "pm.environment.set(\"propID\", propID);",
                      "pm.environment.set(\"tag\", tag);"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "const propertyNames = [",
                      "    \"Vinhomes Central Park\",",
                      "    \"Masteri Thao Dien\",",
                      "    \"The Sun Avenue\",",
                      "    \"Landmark 81 Residences\",",
                      "    \"Saigon Pearl\",",
                      "    \"Gateway Thao Dien\",",
                      "    \"Estella Heights\",",
                      "    \"The Ascent\",",
                      "    \"Riviera Point\",",
                      "    \"Diamond Island\"",
                      "];",
                      "",
                      "const propertyTypes = [",
                      "    \"Can ho chung cu\",",
                      "    \"Nha pho\",",
                      "    \"Biet thu\",",
                      "    \"Nha mat tien\",",
                      "    \"Can ho penthouse\",",
                      "    \"Studio apartment\",",
                      "    \"Shophouse\",",
                      "    \"Condotel\"",
                      "];",
                      "",
                      "const tagPool = [",
                      "    \"ho boi\", \"gym\", \"an ninh 24/7\", \"view song\", \"trung tam thanh pho\",",
                      "    \"gan truong hoc\", \"gan benh vien\", \"ban cong\", \"noi that cao cap\",",
                      "    \"thang may\", \"cho de xe\", \"san thuong\", \"cua hang tien loi\",",
                      "    \"gan metro\", \"khu dan cu van minh\"",
                      "];",
                      "",
                      "const name = propertyNames[Math.floor(Math.random() * propertyNames.length)];",
                      "const type = propertyTypes[Math.floor(Math.random() * propertyTypes.length)];",
                      "const price = Math.floor(Math.random() * (20000000000 - 500000000) + 500000000);",
                      "",
                      "const shuffled = tagPool.sort(() => 0.5 - Math.random());",
                      "const tags = shuffled.slice(0, Math.floor(Math.random() * 3) + 3);",
                      "",
                      "pm.variables.set(\"propName\", name);",
                      "pm.variables.set(\"propType\", type);",
                      "pm.variables.set(\"propPrice\", price);",
                      "pm.variables.set(\"propTags\", JSON.stringify(tags));"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "disabled": false
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\r\n    \"name\": \"{{propName}}\",\r\n    \"description\": \"{{$randomLoremSentence}}\",\r\n    \"price\": {{propPrice}},\r\n    \"location\": {\r\n        \"num\": {{$randomInt}},\r\n        \"street\": \"{{$randomStreetName}}\",\r\n        \"city\": \"{{$randomCity}}\"\r\n    },\r\n    \"type\": \"{{propType}}\",\r\n    \"tags\": {{propTags}}\r\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "http://localhost:3000/properties",
                  "protocol": "http",
                  "host": [
                    "localhost"
                  ],
                  "port": "3000",
                  "path": [
                    "properties"
                  ]
                },
                "description": "Generated from cURL: curl -X POST http://localhost:3000/properties -H \"Content-Type: application/json\" -H \"Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjZhMTY1ZjIzYmZiNWM0ZWI3OGU1NWVhNSIsImlhdCI6MTc3OTg1MzcwOCwiZXhwIjoxNzc5OTQwMTA4fQ.fSJhUancwKP8zlBmkdvntlpsAyAcoaLqEPUCVP0zxes\" -d \"{\\\"name\\\":\\\"{{propName}}\\\",\\\"description\\\":\\\"{{$randomLoremSentence}}\\\",\\\"price\\\":{{propPrice}},\\\"location\\\":{\\\"num\\\":{{$randomInt}},\\\"street\\\":\\\"{{$randomStreetName}}\\\",\\\"city\\\":\\\"{{$randomCity}}\\\"},\\\"type\\\":\\\"{{propType}}\\\",\\\"tags\\\":{{propTags}}}\""
